{
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "nextprintnyc.com" }],
      "destination": "https://www.nextprintnyc.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/banner-designer/designer",
      "destination": "/banner-designer/index.html"
    }
  ],
  "headers": [
    {
      "source": "/websites-demo/start/:path*",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/websites-demo/customize/:path*",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/websites-demo/summary/:path*",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/websites-demo/success/:path*",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/websites-demo/portal/:path*",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/print-products-editor.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    },
    {
      "source": "/print-products-editor.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, max-age=0"
        }
      ]
    }
  ],
  "functions": {
    "api/chat.js": {
      "maxDuration": 10
    },
    "api/upload.js": {
      "maxDuration": 10
    },
    "api/admin.js": {
      "maxDuration": 10
    },
    "api/website-orders.js": {
      "maxDuration": 10
    },
    "api/paypal.js": {
      "maxDuration": 10
    },
    "api/order.js": {
      "maxDuration": 10
    },
    "api/track-order.js": {
      "maxDuration": 10
    },
    "api/member.js": {
      "maxDuration": 10
    },
    "api/create-stripe-checkout-session.js": {
      "maxDuration": 10
    },
    "api/create-stripe-subscription-session.js": {
      "maxDuration": 10
    },
    "api/stripe-webhook.js": {
      "maxDuration": 10
    }
  }
}
